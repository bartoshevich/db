{% if contextVariant == 'post' %}
<nav class="breadcrumbs header__context" aria-label="Хлебные крошки">
  <ol class="breadcrumbs__ol">
    <li class="breadcrumbs__li">
      <a href="/" class="nav-link text-color">Бартошевич</a>
    </li>
    <li class="breadcrumbs__li">
      <a href="/blog/" class="nav-link text-color">Блог</a>
    </li>
    <li class="breadcrumbs__li">
      <span class="element--hidden" aria-current="page">{{ (page.data.name or name or page.data.title or title) | safe }}</span>
    </li>
  </ol>
</nav>
{% elif contextVariant == '404' %}
<nav class="breadcrumbs header__context" aria-label="Хлебные крошки">
  <ol class="breadcrumbs__ol">
    <li class="breadcrumbs__li">
      <a href="/" class="nav-link text-color">Бартошевич</a>
    </li>
    <li class="breadcrumbs__li">
      <span class="text-color" aria-current="page">404</span>
    </li>
  </ol>
</nav>
{% elif contextVariant == 'page' and breadcrumbPages and breadcrumbPages.length > 1 %}
<nav class="breadcrumbs header__context" aria-label="Хлебные крошки">
  <ol class="breadcrumbs__ol">
    {% for itemPage in breadcrumbPages %}
    <li class="breadcrumbs__li{% if loop.last and breadcrumbCount == 3 %} element--hidden{% endif %}">
      {% if loop.last %}
      <span class="text-color" aria-current="page">{{ itemPage.data.eleventyNavigation.title or itemPage.data.title }}</span>
      {% else %}
      <a href="{{ itemPage.url | url }}" class="nav-link text-color">
        {{ itemPage.data.eleventyNavigation.title or itemPage.data.title }}
      </a>
      {% endif %}
    </li>
    {% endfor %}
  </ol>
</nav>
{% elif contextVariant == 'home' %}
<div class="header__context">
  {% if navData and navData.siteName %}
  <span class="logo__title">{{ navData.siteName }}</span>
  {% else %}
  <span class="logo__title">Бартошевич</span>
  {% endif %}
</div>
{% endif %}
