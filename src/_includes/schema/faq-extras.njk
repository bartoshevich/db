{# ================================================================= #}
{# === Модуль Schema.org для страницы FAQ (/faq/)                === #}
{# === Источник данных: src/_data/faq.js                         === #}
{# ================================================================= #}

{% if page.url == "/faq/" %}
  {% set faqPageSchema = {
    "@type": "FAQPage",
    "mainEntity": []
  } %}

  {% for section in faq.sections %}
    {% for item in section.items %}
      {% set questionObject = {
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer | jsonLdText
        }
      } %}
      {% set _ = faqPageSchema.mainEntity.push(questionObject) %}
    {% endfor %}
  {% endfor %}

  {% set _ = schemaParts.push(faqPageSchema) %}
{% endif %}
