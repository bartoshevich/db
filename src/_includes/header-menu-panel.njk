<div class="menu-header__wrapper header__menu-panel-wrapper">
  <div class="menu__header header__menu-panel" id="menu__list">

    <nav class="nav__section" aria-labelledby="main-navigation">
      <p id="main-navigation" class="nav__section__title">{{ navData.title }}</p>
      <ul class="nav__group">
        {% for item in navData.mainNav %}
        <li class="nav__section__item">
          {% if item.url == currentPageUrl %}
          <span class="nav__li--selected" aria-current="page">{{ item.text | safe }}</span>
          {% else %}
          <a href="{{ item.url | url }}" class="nav-link">{{ item.text | safe }}</a>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
    </nav>

    <nav class="nav__section" aria-labelledby="subscription-heading">
      <p id="subscription-heading" class="nav__section__title">{{ navData.subscription.title }}</p>
      <ul class="subscription__list nav__group">
        {% for item in navData.subscription.list %}
        <li class="nav__section__item">
          <a class="nav-link" href="{{ item.url }}"
            {% if item.ariaLabel %} aria-label="{{ item.ariaLabel }}" {% endif %}
            {% if item.type %} type="{{ item.type }}" {% endif %}
            {% if item.title %} title="{{ item.title | safe }}" {% endif %}
            {% if item.external %} target="_blank" rel="noopener noreferrer" {% endif %}>
            {{ item.text }}
          </a>
        </li>
        {% endfor %}
      </ul>
    </nav>

    <nav class="nav__section" aria-labelledby="header-social">
      <p id="header-social" class="nav__section__title">Социальные сети</p>
      {% include "smm.njk" %}
    </nav>

    {% set toggleId = "theme-toggle-header" %}
    {% include "theme-toggle.njk" %}
    {% set toggleId = none %}
    {% set maskId = none %}
  </div>
</div>
